# Used by docker-compose.yml. Copy to .env before running `docker compose up`.

# --- Host ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Resource limits (mem_limit/cpus) are fixed directly in docker-compose.yml,
# not templated here — edit that file if your device needs different values.

# --- Backend runtime configuration (see backend/.env.example for the full list) ---
APP_NAME=Chintu
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
DEFAULT_THEME=system
DEFAULT_LANGUAGE=en-US
# Comma-separated plugin slugs to enable; empty means every plugin found
# under the bind-mounted ./plugins is enabled (PLUGINS_DIR is fixed to
# /app/plugins in docker-compose.yml, not overridable here).
ENABLED_PLUGINS=

# --- Wake-word detection (docs/features/011_Wake_Word.md) ---
# Real detection needs `voice` extras baked into a custom backend image plus
# host mic access — not supported by the default image/compose file (see
# docs/architecture/07_DEPLOYMENT.md's "Voice / Wake Word" section). These
# still matter even without that: they set defaults GET /api/v1/wake-word/status
# reports and POST /api/v1/wake-word/trigger (push-to-talk) always works.
# WAKE_WORD (an optional exact-phrase pin) isn't set here at all by
# docker-compose.yml — see the comment next to it in docker-compose.yml.
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_SENSITIVITY=0.5
WAKE_WORD_PREROLL_SECONDS=1.0
VOICE_AUDIO_DEVICE=

# --- Speech-to-text (docs/features/012_Speech_To_Text.md) ---
# Same `voice`-extras/custom-image caveat as wake-word above. "tiny.en" is
# the only whisper.cpp size that fits this compose file's 512m backend
# mem_limit — see docs/architecture/07_DEPLOYMENT.md.
STT_MODEL=tiny.en
STT_UTTERANCE_SECONDS=5.0

# --- Frontend build-time configuration ---
# Vite inlines this at image build time, so it must point to wherever the
# backend will be reachable from the browser (not from inside the Docker network).
VITE_API_BASE_URL=http://localhost:8000
