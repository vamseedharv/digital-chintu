# Used by docker-compose.yml. Copy to .env before running `docker compose up`.

# --- Host ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Resource limits (mem_limit/cpus) are fixed directly in docker-compose.yml,
# not templated here — edit that file if your device needs different values.

# --- Backend runtime configuration (see backend/.env.example for the full list) ---
APP_NAME=Chintu
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Frontend build-time configuration ---
# Vite inlines this at image build time, so it must point to wherever the
# backend will be reachable from the browser (not from inside the Docker network).
VITE_API_BASE_URL=http://localhost:8000
