APP_NAME=Chintu
APP_ENV=development
DEBUG=true

API_V1_PREFIX=/api/v1

LOG_LEVEL=INFO
LOG_DIR=logs

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=sqlite:///./data/chintu.db

# --- Assistant identity/behavior defaults (backend/app/core/config.py) ---
# Env-driven defaults, not per-user overrides — see docs/features/008_Settings.md.
# Optional: pins an exact wake phrase regardless of APP_NAME. Leave unset
# (the default) to derive "Hey {APP_NAME}" instead — see
# docs/features/011_Wake_Word.md.
# WAKE_WORD=Hey Chintu
# One of: light, dark, system
DEFAULT_THEME=system
# BCP-47-style tag, e.g. "en" or "en-US"
DEFAULT_LANGUAGE=en-US

# --- Plugin extension point (backend/app/core/plugins.py) ---
# Relative to the process's working directory; default matches running
# uvicorn from backend/, landing on the repo-root plugins/.
PLUGINS_DIR=../plugins
# Comma-separated plugin slugs to enable; empty means every discovered
# plugin is enabled.
ENABLED_PLUGINS=

# --- Wake-word detection (backend/app/core/voice/, docs/features/011_Wake_Word.md) ---
# Opt-in: requires `pip install '.[voice]'` (openwakeword/onnxruntime/
# sounddevice). Without it, or without a working input device, the backend
# still boots — GET /api/v1/wake-word/status reports why, and
# POST /api/v1/wake-word/trigger (push-to-talk) always works regardless.
# The runtime on/off switch itself (wake_word_enabled) is DB-backed via
# GET/PATCH /api/v1/settings, not an env var — see 008_Settings.md.
# One of the models openwakeword ships pretrained: alexa, hey_mycroft,
# hey_jarvis, hey_rhasspy. See docs/architecture/07_DEPLOYMENT.md for why
# "Hey Chintu" isn't one of them (no custom wake-word training yet).
WAKE_WORD_MODEL=hey_jarvis
# 0.0-1.0; higher = fewer false wakes but more missed ones.
WAKE_WORD_SENSITIVITY=0.5
# Seconds of audio buffered before a detection and attached to the event
# for the future STT stage (012) to consume.
WAKE_WORD_PREROLL_SECONDS=1.0
# Empty means the system's default input device.
VOICE_AUDIO_DEVICE=
